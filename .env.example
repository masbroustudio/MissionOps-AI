# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GEMINI_MODEL="gemini-3.5-flash"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"

# GROQ PROVIDER ENGINE KEYS
GROQ_API_KEY="MY_GROQ_API_KEY"
GROQ_MODEL="llama-3.3-70b-versatile"

# CEREBRAS WAFER-SCALE ENGINE KEYS
CEREBRAS_API_KEY="MY_CEREBRAS_API_KEY"
CEREBRAS_MODEL="llama3.1-70b"

# SUMOPOD ENTERPRISE CUSTOM RESOLVER
SUMOPOD_API_KEY="MY_SUMOPOD_API_KEY"
SUMOPOD_BASE_URL="MY_SUMOPOD_BASE_URL"
SUMOPOD_MODEL="sumopod-ultra-1"

# LLM ROUTING ORCHESTRATION PREFS
LLM_PROVIDER_ORDER="gemini,groq,cerebras,sumopod,mock"
LLM_TIMEOUT_MS=12000
LLM_MAX_RETRIES=2
